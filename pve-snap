#!/usr/bin/env bash
set -euo pipefail

############################################################
# Proxmox Snapshot Script
#
# Features
# - Supports VM (qm) and Container (pct)
# - Snapshot name format: SYYYYMMDDHHMM
# - Config-driven ITEMS list
# - Silent exit if ITEMS empty
# - Logs warnings/errors to syslog via logger
# - Designed to run from cron.d
############################################################

usage() {
  echo "Usage: $0 [MACHINE_ID ...]"
  exit 1
}

CONF="/etc/pve-snap.conf"

[[ -f "${CONF}" ]] || usage

# cron often runs with a minimal PATH that omits sbin directories
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

############################################################
# Logging
############################################################

LOG_TAG="pve-snap"
LOGGER_BIN="$(command -v logger || true)"
QM_BIN="$(command -v qm || true)"
PCT_BIN="$(command -v pct || true)"

log_error() {
  if [[ -n "$LOGGER_BIN" ]]; then
    "$LOGGER_BIN" -t "$LOG_TAG" -p user.err "$1"
  fi
}

log_warning() {
  if [[ -n "$LOGGER_BIN" ]]; then
    "$LOGGER_BIN" -t "$LOG_TAG" -p user.warning "$1"
  fi
}

log_success() {
  if [[ -n "$LOGGER_BIN" ]]; then
    "$LOGGER_BIN" -t "$LOG_TAG" -p user.notice "$1"
  fi
}

emit_info() {
  echo "$1"
  log_success "$1"
}

emit_warning() {
  echo "$1"
  log_warning "$1"
}

emit_error() {
  echo "$1"
  log_error "$1"
}

# unexpected failures
trap 'log_error "Script failed at line $LINENO (exit code $?)"' ERR

############################################################
# Load configuration
############################################################

# shellcheck disable=SC1090
source "$CONF"

: "${DEFAULT_DESC:=Automated snapshot}"
: "${TZ:=}"
export TZ

############################################################
# Snapshot naming
############################################################

# Format: SYYYYMMDDHHMM
snap_name="S$(date +%Y%m%d%H%M)"

############################################################
# Helpers
############################################################

snapshot_exists_vm() {
  local vmid="$1" name="$2"
  [[ -n "$QM_BIN" ]] || return 1
  "$QM_BIN" listsnapshot "$vmid" 2>/dev/null | awk '{print $1}' | grep -qx "$name"
}

snapshot_exists_ct() {
  local ctid="$1" name="$2"
  [[ -n "$PCT_BIN" ]] || return 1
  "$PCT_BIN" listsnapshot "$ctid" 2>/dev/null | awk '{print $1}' | grep -qx "$name"
}

detect_guest_type() {
  local id="$1"
  local msg

  if [[ -z "$QM_BIN" && -z "$PCT_BIN" ]]; then
    msg="qm and pct commands not found; check PATH for cron jobs"
    emit_error "[ERROR] $msg"
    return 1
  fi

  if [[ -n "$QM_BIN" ]] && "$QM_BIN" status "$id" >/dev/null 2>&1; then
    echo "vm"
    return 0
  fi

  if [[ -n "$PCT_BIN" ]] && "$PCT_BIN" status "$id" >/dev/null 2>&1; then
    echo "ct"
    return 0
  fi

  return 1
}

############################################################
# Snapshot execution
############################################################

do_snapshot_vm() {
  local vmid="$1" name="$2" desc="$3"

  if snapshot_exists_vm "$vmid" "$name"; then
    msg="vm $vmid snapshot '$name' already exists"
    emit_warning "[WARN] $msg"
    return 0
  fi

  emit_info "[RUN ] vm $vmid -> $name"
  if ! "$QM_BIN" snapshot "$vmid" "$name" --description "$desc"; then
    log_error "Snapshot failed for VM $vmid ($name)"
    return 1
  fi

  log_success "Snapshot succeeded for VM $vmid ($name)"
}

do_snapshot_ct() {
  local ctid="$1" name="$2" desc="$3"

  if snapshot_exists_ct "$ctid" "$name"; then
    msg="ct $ctid snapshot '$name' already exists"
    emit_warning "[WARN] $msg"
    return 0
  fi

  emit_info "[RUN ] ct $ctid -> $name"
  if ! "$PCT_BIN" snapshot "$ctid" "$name" --description "$desc"; then
    log_error "Snapshot failed for CT $ctid ($name)"
    return 1
  fi

  log_success "Snapshot succeeded for CT $ctid ($name)"
}

do_snapshot_auto() {
  local id="$1" name="$2" desc="$3"
  local detected_type
  local msg

  if ! detected_type="$(detect_guest_type "$id")"; then
    msg="No VM or CT found for machine ID $id"
    emit_error "[ERROR] $msg"
    return 1
  fi

  case "$detected_type" in
    vm)
      do_snapshot_vm "$id" "$name" "$desc"
      ;;
    ct)
      do_snapshot_ct "$id" "$name" "$desc"
      ;;
  esac
}

############################################################
# Main
############################################################

main() {
  local rc=0

  if [[ $# -gt 0 ]]; then
    for id in "$@"; do
      if ! do_snapshot_auto "$id" "$snap_name" "$DEFAULT_DESC"; then
        rc=1
      fi
    done

    return "$rc"
  fi

  # ---- silent exit if ITEMS undefined or empty ----
  if ! declare -p ITEMS >/dev/null 2>&1 || [[ ${#ITEMS[@]} -eq 0 ]]; then
    return 0
  fi

  for entry in "${ITEMS[@]}"; do
    IFS=',' read -r id desc_override <<<"$entry"
    desc="${desc_override:-$DEFAULT_DESC}"

    if ! do_snapshot_auto "$id" "$snap_name" "$desc"; then
      rc=1
    fi
  done

  return "$rc"
}

main "$@"
